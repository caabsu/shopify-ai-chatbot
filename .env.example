# Shopify
SHOPIFY_SHOP=put1rp-iq
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here
SHOPIFY_API_VERSION=2025-01

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase
SUPABASE_URL=https://wwblkodkycjwmzlflncg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI Configuration
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=https://put1rp-iq.myshopify.com

# JWT Secret (for agent/admin authentication)
JWT_SECRET=change-this-to-a-secure-random-string

# Email (Resend) — for ticket reply emails and confirmations
# Default (used for brands without dedicated keys, e.g. Misu)
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM_ADDRESS=Support <support@yourdomain.com>

# Per-brand Resend overrides: RESEND_API_KEY_<NORMALIZED_SLUG> / EMAIL_FROM_ADDRESS_<NORMALIZED_SLUG>
# Example: warm-by-design -> WARM_BY_DESIGN
RESEND_API_KEY_OUTLIGHT=re_your_outlight_resend_api_key_here
EMAIL_FROM_ADDRESS_OUTLIGHT=Outlight Support <support@outlight.us>
RESEND_API_KEY_WARM_BY_DESIGN=re_your_warm_resend_api_key_here
EMAIL_FROM_ADDRESS_WARM_BY_DESIGN=Warm by Design <support@warmbydesign.com>

# Optional: require a shared secret for inbound email webhooks.
# Send it as Authorization: Bearer <secret>, X-Webhook-Secret, or ?secret=<secret>.
EMAIL_WEBHOOK_SECRET=change-this-to-a-secure-random-string
