{% comment %}
  Outlight Product Reviews — Full review list with ratings, filters, sorting, and review submission.
  Loads review-widget.js which also exposes window.outlightReviews for the V20 carousel section.
{% endcomment %}

{% style %}
  .outlight-reviews-section {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  #outlight-reviews {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 16px;
  }
{% endstyle %}

<div class="outlight-reviews-section">
  <div id="outlight-reviews" data-product-handle="{{ product.handle }}"></div>
</div>

<script src="https://shopify-ai-chatbot-production-9ab4.up.railway.app/widget/review-widget.js" defer></script>

{% schema %}
{
  "name": "Product Reviews",
  "tag": "section",
  "class": "section-outlight-reviews",
  "settings": [
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 720,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 960
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Product Reviews"
    }
  ],
  "templates": ["product"]
}
{% endschema %}
