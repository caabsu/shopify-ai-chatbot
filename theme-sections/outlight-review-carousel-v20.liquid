{% comment %}
  Outlight V20 — Full-Bleed Photo Review Carousel
  Consumes window.outlightReviews from review-widget.js
{% endcomment %}

{{ 'https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200;0,6..72,300;0,6..72,400;1,6..72,200;1,6..72,300&family=Manrope:wght@200;300;400;500&display=swap' | stylesheet_tag }}

{% style %}
  .v20-section {
    --fg: #131314;
    --bg: #F9F9FB;
    --accent: {{ section.settings.star_color | default: '#C5A059' }};
    --body-color: #2d3338;
    --warm: {{ section.settings.no_photo_bg | default: '#f4f0eb' }};
    --border: rgba(19,19,20,0.08);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: var(--bg);
    font-family: 'Manrope', sans-serif;
    -webkit-font-smoothing: antialiased;
    overflow: hidden;
  }

  /* Rating header */
  .v20-rh { text-align: center; padding: 0 44px; margin-bottom: 24px; }
  .v20-rh-stars { display: inline-flex; gap: 2px; margin-bottom: 6px; }
  .v20-rh-stars svg { width: 16px; height: 16px; }
  .v20-rh-num { font-family: 'Newsreader', serif; font-weight: 200; font-size: 1.8rem; color: var(--fg); line-height: 1; }
  .v20-rh-sub { font-size: .7rem; font-weight: 300; color: rgba(45,51,56,.38); margin-top: 4px; }

  /* Heading */
  .v20-heading { text-align: center; margin-bottom: 8px; }
  .v20-heading h2 {
    font-family: 'Newsreader', serif;
    font-weight: 200;
    font-size: 1.6rem;
    color: var(--fg);
    letter-spacing: -0.02em;
    margin: 0;
  }

  /* Carousel wrapper (for arrow positioning) */
  .v20-carousel-wrap { position: relative; }

  /* Carousel track */
  .v20-carousel {
    display: flex;
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding: 0 44px 12px;
    gap: 14px;
  }
  .v20-carousel::-webkit-scrollbar { height: 3px; }
  .v20-carousel::-webkit-scrollbar-thumb { background: rgba(197,160,89,.35); border-radius: 2px; }
  .v20-carousel::-webkit-scrollbar-track { background: rgba(19,19,20,.04); }

  /* Nav arrows */
  .v20-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 44px; height: 44px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.95);
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: var(--fg);
    transition: all .2s;
    backdrop-filter: blur(4px);
  }
  .v20-arrow:hover {
    background: var(--fg);
    color: var(--bg);
    border-color: var(--fg);
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  }
  .v20-arrow:disabled {
    opacity: 0;
    pointer-events: none;
  }
  .v20-arrow svg { width: 18px; height: 18px; stroke-width: 2; }
  .v20-arrow--prev { left: 8px; }
  .v20-arrow--next { right: 8px; }

  /* Card */
  .v20-card {
    flex: 0 0 360px;
    height: 400px;
    scroll-snap-align: start;
    border-radius: 6px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 1px 2px rgba(0,0,0,.03), 0 4px 16px rgba(0,0,0,.04);
    transition: box-shadow .3s, transform .3s;
    cursor: pointer;
  }
  .v20-card:hover {
    box-shadow: 0 2px 4px rgba(0,0,0,.04), 0 8px 28px rgba(0,0,0,.08);
    transform: translateY(-2px);
  }

  /* Background image */
  .v20-card-bg { position: absolute; inset: 0; }
  .v20-card-bg img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .v20-card-grad { position: absolute; inset: 0; background: linear-gradient(transparent 30%, rgba(0,0,0,.7)); }

  /* Content overlay */
  .v20-card-content {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 24px;
    transition: transform .35s ease;
  }
  .v20-card-content .v20-stars { display: inline-flex; gap: 2px; }
  .v20-card-content .v20-stars svg { width: 11px; height: 11px; }
  .v20-card-name { font-size: .88rem; font-weight: 400; color: #fff; margin: 6px 0 4px; }
  .v20-card-name .v20-vf {
    font-size: .55rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--accent);
    margin-left: 4px;
  }
  .v20-card-date { font-size: .62rem; font-weight: 300; color: rgba(255,255,255,.4); }
  .v20-card-snippet {
    font-size: .82rem;
    font-weight: 300;
    color: rgba(255,255,255,.65);
    line-height: 1.6;
    margin: 8px 0 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Expand on hover */
  .v20-card-full { max-height: 0; overflow: hidden; transition: max-height .4s ease, opacity .3s; opacity: 0; }
  .v20-card:hover .v20-card-full { max-height: 200px; opacity: 1; }
  .v20-card-full-text { font-size: .82rem; font-weight: 300; color: rgba(255,255,255,.6); line-height: 1.6; margin: 8px 0; }
  .v20-card-full-foot {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 8px; border-top: 1px solid rgba(255,255,255,.12);
  }
  .v20-card-full-item { font-size: .6rem; font-weight: 300; color: rgba(255,255,255,.3); }
  .v20-card-full-foot .v20-helpful {
    border: 1px solid rgba(255,255,255,.15);
    background: none;
    font-family: 'Manrope', sans-serif;
    font-size: .58rem; font-weight: 400;
    color: rgba(255,255,255,.4);
    padding: 3px 9px; cursor: pointer;
    transition: all .2s;
    display: inline-flex; align-items: center; gap: 3px;
  }
  .v20-card-full-foot .v20-helpful:hover { border-color: var(--accent); color: var(--accent); }
  .v20-card-full-foot .v20-helpful svg { width: 11px; height: 11px; }

  /* No-photo card */
  .v20-card.v20-no-photo { background: var(--warm); }
  .v20-card.v20-no-photo .v20-card-content { position: relative; padding: 28px; }
  .v20-card.v20-no-photo .v20-card-name { color: var(--fg); }
  .v20-card.v20-no-photo .v20-card-name .v20-vf { color: var(--accent); }
  .v20-card.v20-no-photo .v20-card-date { color: rgba(45,51,56,.3); }
  .v20-card.v20-no-photo .v20-card-snippet { color: rgba(45,51,56,.55); -webkit-line-clamp: unset; }
  .v20-card.v20-no-photo .v20-card-full { max-height: none; opacity: 1; }
  .v20-card.v20-no-photo .v20-card-full-text { display: none; }
  .v20-card.v20-no-photo .v20-card-full-foot { border-color: var(--border); }
  .v20-card.v20-no-photo .v20-card-full-item { color: rgba(45,51,56,.28); }
  .v20-card.v20-no-photo .v20-card-full-foot .v20-helpful { border-color: var(--border); color: rgba(45,51,56,.35); }

  /* Skeleton loading */
  .v20-skeleton .v20-card { background: #e8e5e0; animation: v20-pulse 1.5s ease-in-out infinite; }
  .v20-skeleton .v20-card-content { position: relative; padding: 28px; }
  .v20-skel-bar { height: 10px; border-radius: 4px; background: rgba(0,0,0,.06); margin-bottom: 10px; }
  .v20-skel-bar.w60 { width: 60%; }
  .v20-skel-bar.w80 { width: 80%; }
  .v20-skel-bar.w40 { width: 40%; }
  @keyframes v20-pulse { 0%,100% { opacity: .6; } 50% { opacity: 1; } }

  /* Lightbox */
  .v20-lightbox {
    position: fixed; inset: 0; z-index: 99999;
    background: rgba(0,0,0,0.88);
    display: flex; align-items: center; justify-content: center;
    cursor: zoom-out;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    animation: v20-fade-in .2s ease;
  }
  @keyframes v20-fade-in { from { opacity: 0; } to { opacity: 1; } }
  .v20-lightbox img {
    max-width: 92vw; max-height: 92vh;
    object-fit: contain; border-radius: 6px;
    cursor: default;
    box-shadow: 0 8px 60px rgba(0,0,0,0.5);
  }
  .v20-lightbox-close {
    position: absolute; top: 16px; right: 16px;
    width: 40px; height: 40px; border-radius: 50%;
    background: rgba(255,255,255,0.1); border: none;
    color: #fff; font-size: 24px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s;
  }
  .v20-lightbox-close:hover { background: rgba(255,255,255,0.2); }

  /* Hide arrows on mobile */
  @media (max-width: 749px) {
    .v20-arrow { display: none; }
    .v20-carousel {
      padding: 0 20px 10px; gap: 12px;
      scroll-snap-type: x mandatory;
      scroll-behavior: auto;
    }
    .v20-card {
      flex: 0 0 calc(100vw - 48px); height: 360px;
      scroll-snap-align: start;
    }
    .v20-card-content { padding: 20px; }
    .v20-rh { padding: 0 20px; }
    .v20-rh-num { font-size: 1.4rem; }
  }
{% endstyle %}

<div class="v20-section" id="outlight-v20-carousel" data-section-id="{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <div class="v20-heading">
      <h2>{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}

  <!-- Rating header — filled by JS -->
  <div class="v20-rh" id="v20-rh-{{ section.id }}">
    <div class="v20-rh-stars" id="v20-stars-{{ section.id }}"></div>
    <div class="v20-rh-num" id="v20-num-{{ section.id }}">--</div>
    <div class="v20-rh-sub" id="v20-sub-{{ section.id }}">Loading reviews...</div>
  </div>

  <!-- Carousel with nav arrows -->
  <div class="v20-carousel-wrap">
    <button class="v20-arrow v20-arrow--prev" id="v20-prev-{{ section.id }}" disabled aria-label="Previous">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button class="v20-arrow v20-arrow--next" id="v20-next-{{ section.id }}" aria-label="Next">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
    </button>
    <div class="v20-carousel v20-skeleton" id="v20-track-{{ section.id }}">
      {%- for i in (1..5) -%}
        <div class="v20-card">
          <div class="v20-card-content">
            <div class="v20-skel-bar w40"></div>
            <div class="v20-skel-bar w60"></div>
            <div class="v20-skel-bar w80"></div>
            <div class="v20-skel-bar w40"></div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
(function() {
  var SECTION_ID = {{ section.id | json }};
  var ACCENT = {{ section.settings.star_color | default: '#C5A059' | json }};
  var NO_PHOTO_BG = {{ section.settings.no_photo_bg | default: '#f4f0eb' | json }};
  var MAX_CARDS = {{ section.settings.max_cards | default: 12 }};
  var PHOTOS_FIRST = {{ section.settings.photos_first | json }};

  function starSVG(filled, color) {
    var fill = filled ? color : 'none';
    var opacity = filled ? '1' : '0.35';
    var stroke = filled ? color : (color || '#fff');
    return '<svg viewBox="0 0 24 24" width="13" height="13"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="' + fill + '" stroke="' + stroke + '" stroke-width="1" opacity="' + opacity + '"/></svg>';
  }

  function starsHTML(rating, color, size) {
    var full = Math.floor(rating);
    var extra = (rating - full >= 0.75) ? 1 : 0;
    var total = full + extra;
    var h = '';
    for (var i = 0; i < 5; i++) {
      h += starSVG(i < total, color);
    }
    return h;
  }

  function formatDate(d) {
    try {
      var dt = new Date(d);
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      return months[dt.getMonth()] + ' ' + dt.getDate() + ', ' + dt.getFullYear();
    } catch(e) { return d; }
  }

  function thumbSVG() {
    return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>';
  }

  function renderCarousel(data) {
    var reviews = [];
    var summary = null;

    /* Normalize — support multiple response shapes */
    if (data && data.reviews) {
      reviews = data.reviews;
      summary = data.summary || null;
    } else if (data && Array.isArray(data)) {
      reviews = data;
    } else if (data && data.data && Array.isArray(data.data)) {
      reviews = data.data;
    } else if (data && data.results && Array.isArray(data.results)) {
      reviews = data.results;
    }

    if (!reviews.length) return;

    /* Always sort: reviews with photos first */
    reviews = reviews.slice().sort(function(a, b) {
      var aMedia = (a.media && a.media.length) || (a.images && a.images.length) || (a.photos && a.photos.length) || 0;
      var bMedia = (b.media && b.media.length) || (b.images && b.images.length) || (b.photos && b.photos.length) || 0;
      return (bMedia > 0 ? 1 : 0) - (aMedia > 0 ? 1 : 0);
    });

    reviews = reviews.slice(0, MAX_CARDS);

    /* Summary header */
    var starsEl = document.getElementById('v20-stars-' + SECTION_ID);
    var numEl = document.getElementById('v20-num-' + SECTION_ID);
    var subEl = document.getElementById('v20-sub-' + SECTION_ID);

    var avgRating = 0;
    var totalCount = reviews.length;
    if (summary && summary.average_rating) {
      avgRating = summary.average_rating;
      totalCount = summary.total_count || totalCount;
    } else {
      var sum = 0;
      for (var i = 0; i < reviews.length; i++) sum += (reviews[i].rating || 0);
      avgRating = reviews.length ? (sum / reviews.length) : 0;
    }

    if (starsEl) starsEl.innerHTML = starsHTML(avgRating, ACCENT);
    if (numEl) numEl.textContent = avgRating.toFixed(1);
    if (subEl) subEl.textContent = 'Based on ' + totalCount + ' verified review' + (totalCount !== 1 ? 's' : '');

    /* Build cards */
    var track = document.getElementById('v20-track-' + SECTION_ID);
    if (!track) return;

    track.classList.remove('v20-skeleton');
    var html = '';

    for (var i = 0; i < reviews.length; i++) {
      var r = reviews[i];
      var name = r.customer_nickname || r.customer_name || r.reviewer_name || r.author || r.name || 'Anonymous';
      var body = r.body || r.review_text || r.content || r.text || '';
      var rating = r.rating || r.score || 5;
      var verified = r.verified_purchase || r.verified || false;
      var date = r.published_at || r.submitted_at || r.created_at || r.date || '';
      var variant = r.variant_title || r.variant || '';
      var helpful = r.helpful_count || r.helpful || 0;

      /* Get first image URL */
      var imgUrl = '';
      var mediaArr = r.media || r.images || r.photos || [];
      if (mediaArr.length > 0) {
        var first = mediaArr[0];
        imgUrl = (typeof first === 'string') ? first : (first.url || first.src || first.image || '');
        /* Only use image media */
        if (first.media_type && first.media_type !== 'image') imgUrl = '';
      }

      var hasPhoto = !!imgUrl;
      var cardClass = 'v20-card' + (hasPhoto ? '' : ' v20-no-photo');

      html += '<div class="' + cardClass + '"' + (!hasPhoto ? ' style="height:400px"' : '') + (hasPhoto ? ' data-img="' + escapeHTML(imgUrl) + '"' : '') + '>';

      if (hasPhoto) {
        html += '<div class="v20-card-bg"><img src="' + imgUrl + '" alt="" loading="lazy"></div>';
        html += '<div class="v20-card-grad"></div>';
      }

      html += '<div class="v20-card-content">';
      html += '<div class="v20-stars">' + starsHTML(rating, hasPhoto ? '#fff' : ACCENT) + '</div>';
      html += '<div class="v20-card-name">' + escapeHTML(name);
      if (verified) html += ' <span class="v20-vf">verified</span>';
      html += '</div>';
      if (date) html += '<div class="v20-card-date">' + formatDate(date) + '</div>';
      html += '<p class="v20-card-snippet">' + escapeHTML(body) + '</p>';

      /* Expandable footer */
      html += '<div class="v20-card-full">';
      html += '<div class="v20-card-full-foot">';
      if (variant) html += '<span class="v20-card-full-item">' + escapeHTML(variant) + '</span>';
      else html += '<span class="v20-card-full-item"></span>';
      html += '<button class="v20-helpful">' + thumbSVG() + ' ' + helpful + '</button>';
      html += '</div></div>';

      html += '</div></div>';
    }

    track.innerHTML = html;

    /* Attach click-to-lightbox on photo cards */
    var cards = track.querySelectorAll('.v20-card[data-img]');
    for (var c = 0; c < cards.length; c++) {
      cards[c].addEventListener('click', function(e) {
        var src = this.getAttribute('data-img');
        if (!src) return;
        openLightbox(src);
      });
    }

    /* Arrow navigation */
    var prevBtn = document.getElementById('v20-prev-' + SECTION_ID);
    var nextBtn = document.getElementById('v20-next-' + SECTION_ID);
    if (prevBtn && nextBtn) {
      function getScrollAmount() {
        var firstCard = track.querySelector('.v20-card');
        if (!firstCard) return 374;
        return firstCard.offsetWidth + 14; /* card width + gap */
      }
      function updateArrows() {
        var sl = track.scrollLeft;
        var maxScroll = track.scrollWidth - track.clientWidth;
        prevBtn.disabled = sl <= 2;
        nextBtn.disabled = sl >= maxScroll - 2;
      }
      prevBtn.addEventListener('click', function() {
        track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
      });
      nextBtn.addEventListener('click', function() {
        track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
      });
      track.addEventListener('scroll', updateArrows);
      updateArrows();
    }
  }

  function openLightbox(src) {
    var overlay = document.createElement('div');
    overlay.className = 'v20-lightbox';
    overlay.innerHTML = '<button class="v20-lightbox-close">&times;</button><img src="' + src + '" alt="Review photo">';
    overlay.addEventListener('click', function(e) {
      if (e.target === overlay || e.target.classList.contains('v20-lightbox-close')) {
        overlay.remove();
      }
    });
    overlay.querySelector('.v20-lightbox-close').addEventListener('click', function() {
      overlay.remove();
    });
    document.addEventListener('keydown', function handler(e) {
      if (e.key === 'Escape') {
        overlay.remove();
        document.removeEventListener('keydown', handler);
      }
    });
    document.body.appendChild(overlay);
  }

  function escapeHTML(str) {
    if (!str) return '';
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  /* Listen for data from review-widget.js */
  function tryRender() {
    if (window.outlightReviews) {
      renderCarousel(window.outlightReviews);
      return true;
    }
    return false;
  }

  /* If data is already there, render now */
  if (!tryRender()) {
    /* Otherwise wait for the event */
    window.addEventListener('outlight-reviews-loaded', function() {
      tryRender();
    });

    /* Fallback: poll a few times in case timing is tricky */
    var attempts = 0;
    var poll = setInterval(function() {
      attempts++;
      if (tryRender() || attempts > 20) clearInterval(poll);
    }, 500);
  }
})();
</script>

{% schema %}
{
  "name": "Review Carousel V20",
  "tag": "section",
  "class": "section-v20-reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Reviews"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star / accent color",
      "default": "#C5A059"
    },
    {
      "type": "color",
      "id": "no_photo_bg",
      "label": "No-photo card background",
      "default": "#f4f0eb"
    },
    {
      "type": "range",
      "id": "max_cards",
      "label": "Max cards to show",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "photos_first",
      "label": "Show photo reviews first",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Review Carousel V20"
    }
  ]
}
{% endschema %}
