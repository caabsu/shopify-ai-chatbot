{
  "name": "widget-warm",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build:chatbot": "vite build --config vite.chatbot.config.ts",
    "build:returns": "vite build --config vite.returns.config.ts",
    "build:contact": "vite build --config vite.contact.config.ts",
