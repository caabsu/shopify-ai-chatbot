{% comment %}
  Misu Contact + Track Order Section — V03 Warm Split
  Two premium cards side by side (desktop), stacked (mobile).
  Design fetched dynamically from backend API (dashboard-controlled).
  Add as sections/misu-contact-tracking.liquid in your Shopify theme.
{% endcomment %}

<style>
  /* ── Misu CSS Variables ───────────────────────────────────── */
  .misu-ct {
    --bg: hsl(42,42%,92%); --bg-alt: hsl(40,36%,84%); --bg-el: hsl(42,42%,96%);
    --text: hsl(28,48%,14%); --text2: hsl(30,14%,48%); --text3: hsl(30,12%,60%);
    --cta: hsl(28,52%,42%); --cta-h: hsl(28,52%,36%); --cta-t: hsl(40,30%,96%);
    --border: hsl(38,22%,82%); --border-l: hsl(38,20%,88%);
    --font-h: 'DM Serif Display', serif;
    --font-b: 'Bricolage Grotesque', system-ui, sans-serif;
    --brown-rice: hsl(28,32%,58%); --barley: hsl(44,30%,64%);
  }

  /* ── Reset ────────────────────────────────────────────────── */
  .misu-ct *,
  .misu-ct *::before,
  .misu-ct *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .misu-ct {
    background: var(--bg);
    padding: 80px 48px;
    font-family: var(--font-b);
    font-size: 16px;
    line-height: 1.55;
    color: var(--text);
    -webkit-font-smoothing: antialiased;
  }

  .misu-ct-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  /* ── Section Header ───────────────────────────────────────── */
  .misu-ct-section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .misu-ct-eyebrow {
    font-family: var(--font-b);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cta);
    margin-bottom: 18px;
  }

  .misu-ct-section-header h2 {
    font-family: var(--font-h);
    font-size: 44px;
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  /* ── Grid ─────────────────────────────────────────────────── */
  .misu-ct-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }

  /* ── Cards ────────────────────────────────────────────────── */
  .misu-ct-card {
    background: var(--bg-el);
    border-radius: 20px;
    padding: 40px;
    border: 1px solid var(--border-l);
    position: relative;
    overflow: hidden;
  }

  /* Decorative top accent gradients */
  .misu-ct-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
  }

  .misu-ct-card--contact::before {
    background: linear-gradient(90deg, var(--cta), var(--brown-rice));
  }

  .misu-ct-card--track::before {
    background: linear-gradient(90deg, var(--brown-rice), var(--barley));
  }

  /* ── Card Header (icon + title + subtitle) ────────────────── */
  .misu-ct-card-head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 28px;
  }

  .misu-ct-card-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .misu-ct-card-icon svg {
    stroke: var(--cta);
  }

  .misu-ct-card-head h3 {
    font-family: var(--font-h);
    font-size: 22px;
    line-height: 1.15;
    color: var(--text);
  }

  .misu-ct-card-head p {
    font-size: 13px;
    color: var(--text2);
    margin-top: 2px;
  }

  /* ── Form Elements ────────────────────────────────────────── */
  .misu-ct-label {
    display: block;
    font-family: var(--font-b);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text);
    margin-bottom: 6px;
  }

  .misu-ct-input,
  .misu-ct-textarea {
    width: 100%;
    padding: 13px 16px;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    background: var(--bg-el);
    font-family: var(--font-b);
    font-size: 15px;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
  }

  .misu-ct-input:focus,
  .misu-ct-textarea:focus { border-color: var(--cta); }

  .misu-ct-input::placeholder,
  .misu-ct-textarea::placeholder { color: var(--text3); }

  .misu-ct-textarea { resize: vertical; min-height: 120px; line-height: 1.5; }

  .misu-ct-field { margin-bottom: 18px; }

  .misu-ct-row { display: flex; gap: 14px; }
  .misu-ct-row > * { flex: 1; }

  /* ── Buttons ──────────────────────────────────────────────── */
  .misu-ct-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 15px 36px;
    border-radius: 10px;
    background: var(--cta);
    color: var(--cta-t);
    font-family: var(--font-b);
    font-size: 15px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }

  .misu-ct-btn:hover { background: var(--cta-h); }
  .misu-ct-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ── Toggle Tabs ──────────────────────────────────────────── */
  .misu-ct-toggle {
    display: flex;
    background: var(--bg-alt);
    border-radius: 10px;
    padding: 4px;
    margin-bottom: 24px;
  }

  .misu-ct-toggle-btn {
    flex: 1;
    padding: 11px 14px;
    font-family: var(--font-b);
    font-size: 13px;
    font-weight: 600;
    color: var(--text2);
    background: none;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s;
  }

  .misu-ct-toggle-btn.active {
    background: var(--bg-el);
    color: var(--text);
    box-shadow: 0 1px 4px hsla(28,30%,10%,0.1);
  }

  /* ── Tab Panes ────────────────────────────────────────────── */
  .misu-ct-pane { display: none; }
  .misu-ct-pane.active { display: block; }

  /* ── Subject field toggle ─────────────────────────────────── */
  .misu-ct-field--subject { display: block; }
  .misu-ct-field--subject.hidden { display: none; }

  /* ── Need Help section ────────────────────────────────────── */
  .misu-ct-help {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--border-l);
  }

  .misu-ct-help-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--text3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .misu-ct-help-text {
    font-size: 13px;
    color: var(--text2);
    line-height: 1.55;
  }

  .misu-ct-help-text a {
    color: var(--cta);
    font-weight: 600;
    text-decoration: none;
  }

  /* ── Notices ───────────────────────────────────────────────── */
  .misu-ct-notice {
    padding: 12px 16px;
    border-radius: 10px;
    font-size: 14px;
    margin-top: 16px;
    display: none;
  }

  .misu-ct-notice.visible { display: block; }
  .misu-ct-notice.success { background: hsl(142,60%,92%); color: hsl(142,60%,28%); }
  .misu-ct-notice.error { background: hsl(20,100%,95%); color: hsl(20,80%,35%); }

  /* ── Spinner ───────────────────────────────────────────────── */
  .misu-ct-spinner {
    width: 18px; height: 18px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: misu-spin 0.6s linear infinite;
  }
  @keyframes misu-spin { to { transform: rotate(360deg); } }

  /* ── Tracking Result ───────────────────────────────────────── */
  .misu-ct-result {
    background: var(--bg);
    border-radius: 10px;
    padding: 24px;
    margin-top: 24px;
    display: none;
  }
  .misu-ct-result.visible { display: block; }

  .misu-ct-result-header {
    font-size: 12px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 1.2px; color: var(--text3); margin-bottom: 20px;
  }

  /* ── Order Items ───────────────────────────────────────────── */
  .misu-ct-items { margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
  .misu-ct-item { display: flex; align-items: center; gap: 12px; padding: 8px 0; }
  .misu-ct-item-img { width: 48px; height: 48px; border-radius: 8px; object-fit: cover; background: var(--bg-el); border: 1px solid var(--border); }
  .misu-ct-item-info { flex: 1; min-width: 0; }
  .misu-ct-item-title { font-size: 14px; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .misu-ct-item-variant { font-size: 12px; color: var(--text2); margin-top: 2px; }
  .misu-ct-item-qty { font-size: 13px; font-weight: 600; color: var(--text2); flex-shrink: 0; }

  /* ── Status Timeline ───────────────────────────────────────── */
  .misu-ct-timeline { display: flex; flex-direction: column; position: relative; }
  .misu-ct-step { display: flex; align-items: flex-start; gap: 16px; position: relative; padding-bottom: 24px; }
  .misu-ct-step:last-child { padding-bottom: 0; }
  .misu-ct-step::before { content: ''; position: absolute; left: 15px; top: 32px; bottom: 0; width: 2px; background: var(--border); }
  .misu-ct-step:last-child::before { display: none; }
  .misu-ct-step.completed::before { background: var(--cta); }

  .misu-ct-dot {
    width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; position: relative; z-index: 1;
  }
  .misu-ct-step.completed .misu-ct-dot { background: var(--cta); }
  .misu-ct-step.completed .misu-ct-dot svg { display: block; }
  .misu-ct-step.current .misu-ct-dot { background: var(--bg-el); border: 3px solid var(--cta); }
  .misu-ct-step.current .misu-ct-dot::after { content: ''; width: 10px; height: 10px; border-radius: 50%; background: var(--cta); }
  .misu-ct-step.pending .misu-ct-dot { background: var(--bg-el); border: 2px solid var(--border); }

  .misu-ct-step-content { flex: 1; padding-top: 4px; }
  .misu-ct-step-label { font-size: 15px; font-weight: 600; line-height: 1.3; }
  .misu-ct-step.completed .misu-ct-step-label,
  .misu-ct-step.current .misu-ct-step-label { color: var(--cta); }
  .misu-ct-step.pending .misu-ct-step-label { color: var(--text3); }
  .misu-ct-step-date { font-size: 13px; color: var(--text2); margin-top: 2px; }

  /* ── Tracking Details ──────────────────────────────────────── */
  .misu-ct-details { margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border); }
  .misu-ct-detail-row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 13px; }
  .misu-ct-detail-label { color: var(--text2); }
  .misu-ct-detail-value { font-weight: 600; color: var(--text); }

  /* ── Events Log ────────────────────────────────────────────── */
  .misu-ct-events-toggle {
    display: inline-flex; align-items: center; gap: 6px; background: none; border: none;
    font-size: 13px; font-weight: 600; color: var(--text2); cursor: pointer;
    padding: 8px 0; margin-top: 12px; font-family: var(--font-b);
  }
  .misu-ct-events-toggle svg { transition: transform 0.2s; }
  .misu-ct-events-toggle.open svg { transform: rotate(180deg); }
  .misu-ct-events { display: none; margin-top: 8px; }
  .misu-ct-events.open { display: block; }
  .misu-ct-event { display: flex; gap: 12px; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px; }
  .misu-ct-event:last-child { border-bottom: none; }
  .misu-ct-event-time { color: var(--text2); flex-shrink: 0; width: 100px; }
  .misu-ct-event-desc { color: var(--text); flex: 1; }
  .misu-ct-event-loc { color: var(--text2); font-size: 12px; margin-top: 2px; }

  /* ── Responsive (Mobile) ───────────────────────────────────── */
  @media (max-width: 768px) {
    .misu-ct {
      padding: 40px 20px;
    }

    .misu-ct-section-header {
      margin-bottom: 28px;
    }

    .misu-ct-eyebrow {
      margin-bottom: 12px;
    }

    .misu-ct-section-header h2 {
      font-size: 28px;
    }

    .misu-ct-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .misu-ct-card {
      border-radius: 16px;
      padding: 24px 20px;
    }

    .misu-ct-card::before {
      height: 3px;
    }

    .misu-ct-card-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
    }

    .misu-ct-card-icon svg {
      width: 20px;
      height: 20px;
    }

    .misu-ct-card-head h3 {
      font-size: 18px;
    }

    .misu-ct-card-head p {
      font-size: 12px;
    }

    .misu-ct-card-head {
      margin-bottom: 20px;
    }

    .misu-ct-row {
      flex-direction: column;
      gap: 0;
    }

    .misu-ct-toggle {
      margin-bottom: 18px;
    }

    .misu-ct-toggle-btn {
      font-size: 12px;
      padding: 9px 10px;
    }

    .misu-ct-btn {
      font-size: 14px;
      padding: 14px;
    }

    .misu-ct-textarea {
      min-height: 100px;
    }

    .misu-ct-field--subject {
      display: none;
    }
  }
</style>

<div class="misu-ct" id="misu-ct-root">
  <div class="misu-ct-inner">
    <!-- ═══ Section Header ═══ -->
    <div class="misu-ct-section-header">
      <div class="misu-ct-eyebrow">Support</div>
      <h2>We're here to help</h2>
    </div>

    <div class="misu-ct-grid">
      <!-- ═══ Contact Form Card ═══ -->
      <div class="misu-ct-card misu-ct-card--contact" id="misu-ct-contact-card">
        <div class="misu-ct-card-head">
          <div class="misu-ct-card-icon" id="misu-ct-contact-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <h3 id="misu-ct-contact-title">Send a message</h3>
            <p>We respond within 24 hours</p>
          </div>
        </div>

        <form id="misu-contact-form" novalidate>
          <div class="misu-ct-field misu-ct-row">
            <div>
              <label class="misu-ct-label" for="misu-c-name" id="misu-c-name-label">Name</label>
              <input class="misu-ct-input" type="text" id="misu-c-name" placeholder="Your name" required>
            </div>
            <div>
              <label class="misu-ct-label" for="misu-c-email" id="misu-c-email-label">Email</label>
              <input class="misu-ct-input" type="email" id="misu-c-email" placeholder="you@example.com" required>
            </div>
          </div>
          <div class="misu-ct-field misu-ct-field--subject" id="misu-c-subject-field">
            <label class="misu-ct-label" for="misu-c-subject" id="misu-c-subject-label">Subject</label>
            <input class="misu-ct-input" type="text" id="misu-c-subject" placeholder="e.g. Subscription help">
          </div>
          <div class="misu-ct-field">
            <label class="misu-ct-label" for="misu-c-message" id="misu-c-message-label">Message</label>
            <textarea class="misu-ct-textarea" id="misu-c-message" placeholder="What can we help with?" required></textarea>
          </div>
          <button class="misu-ct-btn" type="submit" id="misu-c-btn">
            <span id="misu-c-btn-text">Send message</span>
            <span id="misu-c-btn-arrow">&rarr;</span>
          </button>
          <div class="misu-ct-notice" id="misu-c-notice"></div>
        </form>
      </div>

      <!-- ═══ Track Order Card ═══ -->
      <div class="misu-ct-card misu-ct-card--track">
        <div class="misu-ct-card-head">
          <div class="misu-ct-card-icon" id="misu-ct-track-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5a2 2 0 01-2 2h-1"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
          </div>
          <div>
            <h3 id="misu-ct-track-title">Track your order</h3>
            <p>Real-time status updates</p>
          </div>
        </div>

        <div class="misu-ct-toggle">
          <button class="misu-ct-toggle-btn active" data-pane="order" type="button" id="misu-t-tab-order">Order # + Email</button>
          <button class="misu-ct-toggle-btn" data-pane="tracking" type="button" id="misu-t-tab-tracking">Tracking number</button>
        </div>

        <form class="misu-ct-pane active" id="misu-t-order-pane">
          <div class="misu-ct-field">
            <label class="misu-ct-label" for="misu-t-order">Order number</label>
            <input class="misu-ct-input" type="text" id="misu-t-order" placeholder="#1234" required>
          </div>
          <div class="misu-ct-field">
            <label class="misu-ct-label" for="misu-t-email">Email address</label>
            <input class="misu-ct-input" type="email" id="misu-t-email" placeholder="Email used for order" required>
          </div>
          <button class="misu-ct-btn" type="submit" id="misu-t-btn-order">
            <span>Track order</span>
          </button>
        </form>

        <form class="misu-ct-pane" id="misu-t-tracking-pane">
          <div class="misu-ct-field">
            <label class="misu-ct-label" for="misu-t-tracknum">Tracking number</label>
            <input class="misu-ct-input" type="text" id="misu-t-tracknum" placeholder="Enter your tracking number" required>
          </div>
          <button class="misu-ct-btn" type="submit" id="misu-t-btn-track">
            <span>Track order</span>
          </button>
        </form>

        <div class="misu-ct-notice" id="misu-t-notice"></div>

        <div class="misu-ct-result" id="misu-t-result">
          <div class="misu-ct-items" id="misu-t-items"></div>
          <div class="misu-ct-result-header">ORDER STATUS</div>
          <div class="misu-ct-timeline" id="misu-t-timeline"></div>
          <div class="misu-ct-details" id="misu-t-details"></div>
          <button class="misu-ct-events-toggle" id="misu-t-events-toggle" type="button">
            <span>View all updates</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="misu-ct-events" id="misu-t-events"></div>
        </div>

        <!-- Need help section -->
        <div class="misu-ct-help">
          <div class="misu-ct-help-label">Need help?</div>
          <div class="misu-ct-help-text">Check your order confirmation email for your order number. Can't find it? <a href="mailto:hello@drinkmisu.com">Email us</a>.</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var API = {{ section.settings.backend_url | json }};
  var BRAND = {{ section.settings.brand_slug | json }};
  var ROOT = document.getElementById('misu-ct-root');

  function $(id) { return document.getElementById(id); }
  function show(el, cls) { el.classList.add(cls || 'visible'); }
  function hide(el, cls) { el.classList.remove(cls || 'visible'); }

  function notice(el, msg, type) {
    el.textContent = msg;
    el.className = 'misu-ct-notice visible ' + type;
  }

  function setLoading(btn, loading) {
    var label = btn.querySelector('span');
    if (loading) {
      btn.disabled = true;
      btn._text = label.textContent;
      label.textContent = '';
      var sp = document.createElement('div');
      sp.className = 'misu-ct-spinner';
      btn.insertBefore(sp, label);
    } else {
      btn.disabled = false;
      label.textContent = btn._text || '';
      var sp = btn.querySelector('.misu-ct-spinner');
      if (sp) sp.remove();
    }
  }

  function fmtDate(iso) {
    if (!iso) return '';
    var d = new Date(iso);
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function fmtTime(iso) {
    if (!iso) return '';
    var d = new Date(iso);
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) +
      ' ' + d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
  }

  /* ═══════════════════════════════════════════════════════════════
     DYNAMIC DESIGN — Fetch from API and apply as CSS variables
     ═══════════════════════════════════════════════════════════════ */
  var successMsg = "Message sent! We'll get back to you soon.";

  function applyContactDesign(d) {
    if (!d) return;
    var s = ROOT.style;
    if (d.primaryColor)       s.setProperty('--cta', d.primaryColor);
    if (d.accentColor)        s.setProperty('--cta', d.accentColor);
    if (d.backgroundColor)    s.setProperty('--bg-el', d.backgroundColor);
    if (d.inputBackground)    s.setProperty('--bg-el', d.inputBackground);
    if (d.borderColor)        s.setProperty('--border', d.borderColor);
    if (d.textColor)          s.setProperty('--text', d.textColor);
    if (d.labelColor)         s.setProperty('--text', d.labelColor);
    if (d.placeholderColor)   s.setProperty('--text3', d.placeholderColor);
    if (d.headingFontFamily)  s.setProperty('--font-h', d.headingFontFamily);
    if (d.bodyFontFamily)     s.setProperty('--font-b', d.bodyFontFamily);

    if (d.headerTitle) $('misu-ct-contact-title').textContent = d.headerTitle;
    if (d.nameLabel) $('misu-c-name-label').textContent = d.nameLabel;
    if (d.namePlaceholder) $('misu-c-name').placeholder = d.namePlaceholder;
    if (d.emailLabel) $('misu-c-email-label').textContent = d.emailLabel;
    if (d.emailPlaceholder) $('misu-c-email').placeholder = d.emailPlaceholder;
    if (d.subjectLabel) $('misu-c-subject-label').textContent = d.subjectLabel;
    if (d.subjectPlaceholder) $('misu-c-subject').placeholder = d.subjectPlaceholder;
    if (d.messageLabel) $('misu-c-message-label').textContent = d.messageLabel;
    if (d.messagePlaceholder) $('misu-c-message').placeholder = d.messagePlaceholder;
    if (d.buttonText) $('misu-c-btn-text').textContent = d.buttonText;
    if (d.successMessage) successMsg = d.successMessage;

    if (d.showSubjectField === false) {
      $('misu-c-subject-field').classList.add('hidden');
    } else {
      $('misu-c-subject-field').classList.remove('hidden');
    }

    var arrow = $('misu-c-btn-arrow');
    if (arrow) arrow.style.display = d.buttonShowArrow === false ? 'none' : '';
  }

  function applyTrackingDesign(d) {
    if (!d) return;
    if (d.headerText) $('misu-ct-track-title').textContent = d.headerText;
    if (d.tabOrderLabel) $('misu-t-tab-order').textContent = d.tabOrderLabel;
    if (d.tabTrackingLabel) $('misu-t-tab-tracking').textContent = d.tabTrackingLabel;
    if (d.buttonText) {
      $('misu-t-btn-order').querySelector('span').textContent = d.buttonText;
      $('misu-t-btn-track').querySelector('span').textContent = d.buttonText;
    }
  }

  // Fetch both configs in parallel
  Promise.all([
    fetch(API + '/api/contact-form/widget/config?brand=' + BRAND)
      .then(function(r) { return r.ok ? r.json() : null; })
      .catch(function() { return null; }),
    fetch(API + '/api/tracking/widget/config?brand=' + BRAND)
      .then(function(r) { return r.ok ? r.json() : null; })
      .catch(function() { return null; })
  ]).then(function(results) {
    if (results[0] && results[0].widget_design) applyContactDesign(results[0].widget_design);
    if (results[1] && results[1].widget_design) applyTrackingDesign(results[1].widget_design);
  });

  /* ═══════════════════════════════════════════════════════════════
     CONTACT FORM
     ═══════════════════════════════════════════════════════════════ */
  var cForm = $('misu-contact-form');
  var cNotice = $('misu-c-notice');

  cForm.addEventListener('submit', function(e) {
    e.preventDefault();
    hide(cNotice, 'visible');
    var btn = $('misu-c-btn');
    setLoading(btn, true);

    var body = {
      name: $('misu-c-name').value.trim(),
      email: $('misu-c-email').value.trim(),
      subject: $('misu-c-subject').value.trim(),
      message: $('misu-c-message').value.trim(),
      category: 'general'
    };

    if (!body.name || !body.email || !body.message) {
      setLoading(btn, false);
      notice(cNotice, 'Please fill in all required fields.', 'error');
      return;
    }

    fetch(API + '/api/tickets/form?brand=' + BRAND, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    })
    .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
    .then(function(res) {
      setLoading(btn, false);
      if (res.ok && res.data.ticketNumber) {
        notice(cNotice, successMsg + ' Ticket #' + res.data.ticketNumber, 'success');
        cForm.reset();
      } else {
        notice(cNotice, res.data.error || 'Something went wrong. Please try again.', 'error');
      }
    })
    .catch(function() {
      setLoading(btn, false);
      notice(cNotice, 'Network error. Please check your connection.', 'error');
    });
  });

  /* ═══════════════════════════════════════════════════════════════
     TRACK ORDER — TABS
     ═══════════════════════════════════════════════════════════════ */
  var tabs = document.querySelectorAll('.misu-ct-toggle-btn');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      tabs.forEach(function(t) { t.classList.remove('active'); });
      tab.classList.add('active');
      document.querySelectorAll('.misu-ct-pane').forEach(function(p) { p.classList.remove('active'); });
      $('misu-t-' + tab.dataset.pane + '-pane').classList.add('active');
      hide($('misu-t-result'), 'visible');
      hide($('misu-t-notice'), 'visible');
    });
  });

  /* ═══════════════════════════════════════════════════════════════
     TRACK ORDER — SUBMIT
     ═══════════════════════════════════════════════════════════════ */
  var tNotice = $('misu-t-notice');
  var tResult = $('misu-t-result');

  function doTrack(url, body, btn) {
    hide(tNotice, 'visible');
    hide(tResult, 'visible');
    setLoading(btn, true);

    fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-brand': BRAND },
      body: JSON.stringify(body)
    })
    .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
    .then(function(res) {
      setLoading(btn, false);
      if (!res.ok || res.data.error) {
        notice(tNotice, res.data.error || res.data.statusMessage || 'Order not found. Please check your details.', 'error');
        return;
      }
      renderResult(res.data);
    })
    .catch(function() {
      setLoading(btn, false);
      notice(tNotice, 'Network error. Please check your connection.', 'error');
    });
  }

  $('misu-t-order-pane').addEventListener('submit', function(e) {
    e.preventDefault();
    var orderNum = $('misu-t-order').value.trim().replace(/^#/, '');
    var email = $('misu-t-email').value.trim();
    if (!orderNum || !email) { notice(tNotice, 'Please fill in both fields.', 'error'); return; }
    doTrack(API + '/api/tracking/lookup', { order_number: orderNum, email: email }, $('misu-t-btn-order'));
  });

  $('misu-t-tracking-pane').addEventListener('submit', function(e) {
    e.preventDefault();
    var num = $('misu-t-tracknum').value.trim();
    if (!num) { notice(tNotice, 'Please enter a tracking number.', 'error'); return; }
    doTrack(API + '/api/tracking/track', { tracking_number: num }, $('misu-t-btn-track'));
  });

  /* ═══════════════════════════════════════════════════════════════
     RENDER TRACKING RESULT
     ═══════════════════════════════════════════════════════════════ */
  var STEPS = [
    { key: 'ordered', label: 'Ordered' },
    { key: 'processing', label: 'Processing' },
    { key: 'shipped', label: 'Shipped' },
    { key: 'delivered', label: 'Delivered' }
  ];

  var STATUS_MAP = {
    'info_received': 1,
    'in_transit': 2,
    'out_for_delivery': 2,
    'delivered': 3,
    'exception': 2
  };

  function renderResult(data) {
    var itemsEl = $('misu-t-items');
    itemsEl.innerHTML = '';
    if (data.order && data.order.lineItems && data.order.lineItems.length) {
      data.order.lineItems.forEach(function(li) {
        var div = document.createElement('div');
        div.className = 'misu-ct-item';
        var imgHtml = li.imageUrl
          ? '<img class="misu-ct-item-img" src="' + li.imageUrl + '" alt="">'
          : '<div class="misu-ct-item-img"></div>';
        div.innerHTML = imgHtml +
          '<div class="misu-ct-item-info">' +
            '<div class="misu-ct-item-title">' + li.title + '</div>' +
            (li.variant && li.variant !== 'Default Title' ? '<div class="misu-ct-item-variant">' + li.variant + '</div>' : '') +
          '</div>' +
          '<div class="misu-ct-item-qty">x' + li.quantity + '</div>';
        itemsEl.appendChild(div);
      });
      itemsEl.style.display = '';
    } else {
      itemsEl.style.display = 'none';
    }

    var activeIdx = STATUS_MAP[data.status] != null ? STATUS_MAP[data.status] : 0;
    var timelineEl = $('misu-t-timeline');
    timelineEl.innerHTML = '';
    var checkSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>';

    STEPS.forEach(function(step, i) {
      var state = i < activeIdx ? 'completed' : (i === activeIdx ? 'current' : 'pending');
      var dateText = '';

      if (i === 0 && data.order) {
        dateText = data.events && data.events.length ? fmtDate(data.events[data.events.length - 1].timestamp) : '';
      } else if (i === 3 && data.status === 'delivered' && data.deliveredAt) {
        dateText = fmtDate(data.deliveredAt);
      } else if (i === activeIdx) {
        dateText = data.statusDetail || data.statusMessage || '';
        if (i === 2 && data.status === 'in_transit') dateText = 'In transit';
        if (i === 2 && data.status === 'out_for_delivery') dateText = 'Out for delivery';
      } else if (i === 3 && state === 'pending' && data.estimatedDelivery) {
        dateText = 'Est. ' + fmtDate(data.estimatedDelivery);
      }

      if ((state === 'completed' || state === 'current') && !dateText && data.events && data.events.length) {
        var statusMatch = { 0: 'CONFIRMED', 1: 'IN_TRANSIT', 2: 'IN_TRANSIT', 3: 'DELIVERED' };
        for (var e = 0; e < data.events.length; e++) {
          if (data.events[e].status === statusMatch[i] || data.events[e].description.toLowerCase().indexOf(step.label.toLowerCase()) > -1) {
            dateText = fmtDate(data.events[e].timestamp);
            break;
          }
        }
      }

      var div = document.createElement('div');
      div.className = 'misu-ct-step ' + state;
      div.innerHTML =
        '<div class="misu-ct-dot">' + (state === 'completed' ? checkSvg : '') + '</div>' +
        '<div class="misu-ct-step-content">' +
          '<div class="misu-ct-step-label">' + step.label + '</div>' +
          (dateText ? '<div class="misu-ct-step-date">' + dateText + '</div>' : '') +
        '</div>';
      timelineEl.appendChild(div);
    });

    var detailsEl = $('misu-t-details');
    var rows = '';
    if (data.carrier) rows += '<div class="misu-ct-detail-row"><span class="misu-ct-detail-label">Carrier</span><span class="misu-ct-detail-value">' + (data.carrierDisplay || data.carrier) + '</span></div>';
    if (data.trackingNumber) rows += '<div class="misu-ct-detail-row"><span class="misu-ct-detail-label">Tracking #</span><span class="misu-ct-detail-value">' + data.trackingNumber + '</span></div>';
    if (data.order && data.order.destination) rows += '<div class="misu-ct-detail-row"><span class="misu-ct-detail-label">Destination</span><span class="misu-ct-detail-value">' + data.order.destination + '</span></div>';
    if (data.order && data.order.transitDays != null) rows += '<div class="misu-ct-detail-row"><span class="misu-ct-detail-label">Transit time</span><span class="misu-ct-detail-value">' + data.order.transitDays + ' days</span></div>';
    if (data.estimatedDelivery) rows += '<div class="misu-ct-detail-row"><span class="misu-ct-detail-label">Est. delivery</span><span class="misu-ct-detail-value">' + fmtDate(data.estimatedDelivery) + '</span></div>';
    if (data.signedBy) rows += '<div class="misu-ct-detail-row"><span class="misu-ct-detail-label">Signed by</span><span class="misu-ct-detail-value">' + data.signedBy + '</span></div>';
    detailsEl.innerHTML = rows;
    detailsEl.style.display = rows ? '' : 'none';

    var eventsToggle = $('misu-t-events-toggle');
    var eventsEl = $('misu-t-events');
    eventsEl.classList.remove('open');
    eventsToggle.classList.remove('open');

    if (data.events && data.events.length) {
      eventsEl.innerHTML = '';
      data.events.forEach(function(ev) {
        var div = document.createElement('div');
        div.className = 'misu-ct-event';
        div.innerHTML =
          '<div class="misu-ct-event-time">' + fmtTime(ev.timestamp) + '</div>' +
          '<div><div class="misu-ct-event-desc">' + ev.description + '</div>' +
          (ev.location ? '<div class="misu-ct-event-loc">' + ev.location + '</div>' : '') +
          '</div>';
        eventsEl.appendChild(div);
      });
      eventsToggle.style.display = '';
    } else {
      eventsToggle.style.display = 'none';
    }

    show(tResult, 'visible');
  }

  $('misu-t-events-toggle').addEventListener('click', function() {
    this.classList.toggle('open');
    $('misu-t-events').classList.toggle('open');
    this.querySelector('span').textContent = this.classList.contains('open') ? 'Hide updates' : 'View all updates';
  });
})();
</script>

{% schema %}
{
  "name": "Misu Contact + Tracking",
  "tag": "section",
  "class": "misu-contact-tracking-section",
  "settings": [
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width (px)",
      "min": 800,
      "max": 1400,
      "step": 20,
      "default": 1100
    },
    {
      "type": "text",
      "id": "backend_url",
      "label": "Backend URL",
      "default": "https://shopify-ai-chatbot-production-9ab4.up.railway.app"
    },
    {
      "type": "text",
      "id": "brand_slug",
      "label": "Brand slug",
      "default": "misu"
    }
  ],
  "presets": [
    {
      "name": "Misu Contact + Tracking"
    }
  ]
}
{% endschema %}
